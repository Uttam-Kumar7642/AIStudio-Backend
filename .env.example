# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Option A: Local MongoDB (easiest for dev)
MONGODB_URI=mongodb+srv://uttam:uttam123@cluster0.dspi7bs.mongodb.net/ai-saas

# Option B: MongoDB Atlas - replace with YOUR string
# MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ai-saas?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=supersecretjwtkey_change_this_in_production_min32chars
JWT_EXPIRE=7d

# ─── AI APIs ──────────────────────────────────────────────────────────────────
# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# Get Gemini key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSyDt3AuoOmCzkaaApD0RRoN_GLPCLaoVKIE
# AI_MODEL=gemini-1.0-pro

# Which provider to use: 'openai' or 'gemini'
AI_PROVIDER=gemini
GEMINI_API_KEY=Your_Gemini_api_key

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
